{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "VFR ATC Director: Console Mode",
            "type": "debugpy",
            "request": "launch",
            "module": "vfr_atc_director.main",
            "args": ["--mode", "console"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/google-agent-kit",
            "envFile": "${workspaceFolder}/google-agent-kit/vfr_atc_director/.env"
        },
        {
            "name": "VFR ATC Director: Audio Mode",
            "type": "debugpy",
            "request": "launch",
            "module": "vfr_atc_director.main",
            "args": ["--mode", "audio"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/google-agent-kit",
            "envFile": "${workspaceFolder}/google-agent-kit/vfr_atc_director/.env"
        },
        {
            "name": "VFR ATC Director: Info",
            "type": "debugpy",
            "request": "launch",
            "module": "vfr_atc_director.main",
            "args": ["--mode", "info"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/google-agent-kit",
            "envFile": "${workspaceFolder}/google-agent-kit/vfr_atc_director/.env"
        },
        {
            "name": "PR Review Swarm: Main",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/agentswarm/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/agentswarm",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/agentswarm"
            }
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}